# Copia este archivo como .env.local y completa con los valores de tu
# proyecto de Supabase (Settings → API). El archivo .env.local NO se sube
# a GitHub (está en .gitignore).

# --- Cliente (públicas por diseño; la seguridad la pone el RLS) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU-ANON-KEY

# --- Solo servidor (configurar en Vercel → Environment Variables) ---
# Clave privada para el worker de notificaciones. JAMÁS con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
# API key de resend.com para enviar correos.
RESEND_API_KEY=
# Remitente. Sin dominio propio verificado usa: Azenda <onboarding@resend.dev>
RESEND_FROM=
# Secreto del cron de Vercel (Vercel lo envía automáticamente si existe).
# Genera uno aleatorio largo, ej: openssl rand -hex 32
CRON_SECRET=
